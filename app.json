{
  "expo": {
    "name": "Velo",
    "slug": "velo-app",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "velo",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSHealthShareUsageDescription": "Velo reads your workouts, heart rate, HRV, sleep, steps, and body data to power your training dashboard.",
        "NSHealthUpdateUsageDescription": "Velo does not write to Apple Health.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.raine.ye.veloapp"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0a0a0a"
        }
      ],
      "expo-web-browser",
      [
        "react-native-health",
        {
          "healthSharePermission": "Velo reads workouts and health data to track your training.",
          "healthUpdatePermission": "Velo does not write to Apple Health."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4386767a-00d3-4ff4-a9ea-40f62a65cc62"
      }
    },
    "owner": "raine.ye"
  }
}
